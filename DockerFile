FROM eclipse-temurin:25-jdk-jammy AS build

WORKDIR /workspace

COPY .mvn/ .mvn/
COPY mvnw pom.xml ./

RUN chmod +x mvnw
RUN ./mvnw -B dependency:go-offline

COPY src/ src/

# Always clean before packaging so the image contains the current templates and frontend assets.
RUN ./mvnw -B -DskipTests clean package


FROM eclipse-temurin:25-jre-jammy AS runtime

WORKDIR /app

RUN groupadd --system internconnect \
    && useradd --system --gid internconnect internconnect

COPY --from=build --chown=internconnect:internconnect /workspace/target/*.war app.war

USER internconnect:internconnect

EXPOSE 8080

ENV SPRING_PROFILES_ACTIVE=docker
ENV JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.war"]
